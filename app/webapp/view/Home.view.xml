<mvc:View
	controllerName="com.mmd.controller.Home"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	height="100%"
	class="homeView">
	<Page id="homePage" title="{i18n>nav.home}" showNavButton="false" showHeader="false" class="homePage">
		<content>
			<l:VerticalLayout width="100%" class="homeContentWrapper">
				<l:content>
					<l:VerticalLayout class="sapUiLargeMarginTop homeContentWidth homeContentMarginBegin">
						<l:content>
							<HBox wrap="Wrap" alignItems="Start" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
								<VBox class="sapUiSmallMarginEnd">
									<Title level="H1" text="{i18n>home.hero.headline}" class="sapUiMediumMarginTop homeHeading" />
									<Text text="{i18n>home.hero.subline}" class="sapUiMediumMarginTop sapUiSmallMarginBottom" />
								</VBox>
								<VBox>
									<core:HTML
										content="&lt;div class=&quot;profilePictureContainer&quot;&gt;&lt;img id=&quot;profilePictureImg&quot; alt=&quot;Profile&quot; class=&quot;profilePicture&quot; /&gt;&lt;/div&gt;" />
								</VBox>
							</HBox>

							<Panel
								width="90%"
								headerText="{i18n>home.about.title}"
								class="sapUiMediumMarginTop sapUiContentPadding whoAmIPanel"
								expandable="true"
								expanded="true">
								<content>
									<l:VerticalLayout class="sapUiSmallMargin" width="90%">
										<l:content>
											<Text text="{i18n>home.about.intro}" class="sapUiSmallMarginBottom" />
											<Text text="{i18n>home.about.focus}" class="sapUiSmallMarginTop" />
											<List class="sapUiSmallMarginTop">
												<StandardListItem title="{i18n>home.about.focus.cap}" />
												<StandardListItem title="{i18n>home.about.focus.ui5}" />
												<StandardListItem title="{i18n>home.about.focus.btp}" />
												<StandardListItem title="{i18n>home.about.focus.architecture}" />
											</List>
											<Link
												text="{i18n>home.about.github}"
												href="https://github.com/mandev-1"
												target="_blank"
												class="sapUiSmallMarginTop" />
										</l:content>
									</l:VerticalLayout>
								</content>
							</Panel>
						</l:content>
					</l:VerticalLayout>

					<l:VerticalLayout class="homeMobileSection sapUiMediumMarginTop">
						<l:content>
							<core:HTML content="&lt;div style=&quot;flex: 1; min-height: 60px;&quot;&gt;&lt;/div&gt;" />
						</l:content>
					</l:VerticalLayout>

					<l:HorizontalLayout class="sapUiLargeMarginBottom sapUiLargeMarginBegin homeContentWidth homeMobileSection">
						<l:content>
							<Button
								text="{i18n>home.hero.cta.projects}"
								type="Emphasized"
								press="onViewProjects"
								class="homeProjectButton" />
							<Link
								text="{i18n>home.hero.cta.connect}"
								press="onConnectProfessionally"
								class="sapUiMediumMarginBegin homeConnectLink" />
						</l:content>
					</l:HorizontalLayout>

					<f:GridContainer id="topTilesGrid" class="sapUiLargeMarginBottom homeContentMarginBegin sapUiNoContentPadding sapUiTinyMarginBegin homeMobileSection">
						<GenericTile
							header="{i18n>home.tile.meeting}"
							subheader="{i18n>home.tile.meeting.sub}"
							press="pressOnTileTwo">
							<layoutData>
								<f:GridContainerItemLayoutData rows="2" columns="2" />
							</layoutData>
							<TileContent>
								<ImageContent src="sap-icon://calendar" />
							</TileContent>
						</GenericTile>
						<GenericTile
							header="{i18n>home.tile.abap}"
							subheader="{i18n>home.tile.abap.sub}"
							press="goToABAPDevelopment">
							<layoutData>
								<f:GridContainerItemLayoutData rows="2" columns="2" />
							</layoutData>
							<TileContent>
								<ImageContent src="sap-icon://education" />
							</TileContent>
						</GenericTile>
						<GenericTile
							header="{i18n>home.tile.demo}"
							subheader="{i18n>home.tile.demo.sub}"
							press="onNavigateToDemo">
							<layoutData>
								<f:GridContainerItemLayoutData rows="2" columns="2" />
							</layoutData>
							<TileContent>
								<ImageContent src="sap-icon://artificial-intelligence" />
							</TileContent>
						</GenericTile>
						<GenericTile
							header="{i18n>home.tile.fortyTwo}"
							subheader="{i18n>home.tile.fortyTwo.sub}"
							press="onNavigateTo42Prague">
							<layoutData>
								<f:GridContainerItemLayoutData rows="2" columns="2" />
							</layoutData>
							<TileContent>
								<ImageContent src="sap-icon://study-leave" />
							</TileContent>
						</GenericTile>
					</f:GridContainer>
				</l:content>
			</l:VerticalLayout>
		</content>
	</Page>
</mvc:View>
