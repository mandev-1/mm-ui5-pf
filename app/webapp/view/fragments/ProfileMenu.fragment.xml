<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<List>
		<items>
			<!-- Dark Mode Toggle -->
			<StandardListItem
				id="darkModeListItem"
				icon="{= ${language>/darkMode} ? 'sap-icon://light-mode' : 'sap-icon://dark-mode'}"
				title="{= ${language>/darkMode} ? ${i18n>profile.lightMode} : ${i18n>profile.darkMode}}"
				type="Active"
				press=".onDarkModePress" />
			<StandardListItem
				id="languageModeListItem"
				icon="{= ${language>/mode} === 'work' ? 'sap-icon://palette' : 'sap-icon://business-objects-experience'}"
				title="{= ${language>/mode} === 'work' ? ${i18n>profile.funMode} : ${i18n>profile.workMode}}"
				type="Active"
				press=".onLanguageModePress" />
		</items>
	</List>
</core:FragmentDefinition>
